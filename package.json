{
  "name": "b2-transformers-video-object-detection",
  "version": "1.0.0",
  "description": "Real-time Video Object Detection with Transformers.js and Backblaze B2",
  "scripts": {
    "install:backend": "cd backend && npm install",
    "start:backend": "cd backend && npm start",
    "dev:backend": "cd backend && npm run dev",
    "start:frontend": "cd frontend && python3 -m http.server 8080",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "keywords": ["yolov9", "object-detection", "video-object-detection", "real-time-detection", "computer-vision", "coco", "bounding-box", "webcam", "transformers-js", "webassembly", "browser-ai", "client-side-ai", "backblaze", "b2", "s3", "cloud-storage", "javascript", "monitoring"],
